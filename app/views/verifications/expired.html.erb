<% content_for(:title, "Link expired | mcp-analytics") %>
<% content_for(:body_class, "home") %>
<% content_for(:track_event, "verify_expired") %>

<% content_for :head do %>
  <%= render "layouts/fonts" %>

  <style>
    body.home {
      --bg: #ffffff; --fg: #0a0a0a; --accent: #00FF88; --border: 3px;
      background: var(--bg); color: var(--fg);
      font-family: "JetBrains Mono", ui-monospace, Menlo, Consolas, monospace;
      font-size: 16px; line-height: 1.55;
    }
    body.home main { max-width: none; padding: 0; margin: 0; }
    body.home .wrap { max-width: 720px; margin: 0 auto; padding: 96px 28px 120px; }
    body.home h1 {
      font-family: "Space Grotesk", sans-serif; font-weight: 900;
      font-size: clamp(40px, 7vw, 80px); line-height: 0.95;
      letter-spacing: -0.03em; margin: 0 0 24px; text-transform: uppercase;
    }
    body.home h1 .accent { background: var(--accent); padding: 0 0.15em; margin-left: -0.15em; }
    body.home p { font-size: 17px; margin: 0 0 16px; }
    body.home a { color: var(--fg); text-decoration: underline; }
    body.home a:hover { background: var(--accent); }
    body.home code {
      font-family: "JetBrains Mono", monospace; font-size: 14px;
      background: #f5f5f5; padding: 2px 6px; border: 1px solid #ddd;
    }
    body.home footer.lp {
      margin-top: 64px;
      border-top: var(--border) solid var(--fg);
      padding-top: 16px; font-size: 12px; color: #666;
    }
  </style>
<% end %>

<div class="wrap">
  <h1>Link <span class="accent">expired</span>.</h1>
  <p>Verification links are valid for 24 hours.</p>
  <p>Ask your MCP client to call <code>register_account</code> again with your email — or <%= link_to "request a fresh one here", root_path(anchor: "signup-form") %>.</p>

  <footer class="lp">
    <%= link_to "← Back home", root_path %>
  </footer>
</div>
