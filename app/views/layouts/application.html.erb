<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "mcp-analytics" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Analytics for your AI workflow. Query your data via MCP instead of clicking through dashboards.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= yield :head %>

    <%# Dogfooding: mcp-analytics tracking its own site. %>
    <% if Rails.env.production? %>
      <script defer data-site="wjxayhdd" src="https://t.mcp-analytics.com/script.js"></script>
    <% end %>
  </head>

  <body class="<%= content_for?(:body_class) ? content_for(:body_class) : '' %>">
    <main>
      <% if notice %><div class="notice"><%= notice %></div><% end %>
      <%= yield %>
    </main>
  </body>
</html>
