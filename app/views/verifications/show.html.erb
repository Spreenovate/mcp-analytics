<% content_for(:title, "Confirm sign-in | mcp-analytics") %>
<% content_for(:body_class, "home") %>

<% content_for :head do %>
  <meta name="robots" content="noindex, nofollow">
  <meta name="referrer" content="no-referrer">
  <%= render "layouts/fonts" %>

  <style>
    body.home {
      --bg: #ffffff; --fg: #0a0a0a; --accent: #00FF88; --border: 3px;
      background: var(--bg); color: var(--fg);
      font-family: "JetBrains Mono", ui-monospace, Menlo, Consolas, monospace;
      font-size: 16px; line-height: 1.55;
    }
    body.home main { max-width: none; padding: 0; margin: 0; }
    body.home .wrap { max-width: 720px; margin: 0 auto; padding: 80px 28px 120px; }
    body.home h1 {
      font-family: "Space Grotesk", sans-serif; font-weight: 900;
      font-size: clamp(40px, 7vw, 72px); line-height: 0.95;
      letter-spacing: -0.03em; margin: 0 0 24px;
      text-transform: uppercase;
    }
    body.home h1 .accent { position: relative; color: var(--fg); }
    body.home h1 .accent::before {
      content: ""; position: absolute; z-index: -1;
      top: -0.05em; bottom: -0.05em; left: -0.15em; right: -0.05em;
      background: var(--accent);
    }
    body.home .lead { font-size: 18px; margin: 0 0 36px; color: #444; }
    body.home .panel {
      border: var(--border) solid var(--fg);
      padding: 24px; margin: 0 0 32px;
    }
    body.home .panel .label {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.12em; background: var(--fg); color: var(--bg);
      padding: 4px 8px; display: inline-block; margin-bottom: 14px;
    }
    body.home .btn {
      font: inherit; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
      background: var(--fg); color: var(--accent); border: var(--border) solid var(--fg);
      padding: 16px 28px; cursor: pointer; font-size: 16px;
    }
    body.home .btn:hover { background: var(--accent); color: var(--fg); }
    body.home .footer-link { margin-top: 48px; font-size: 13px; color: #666; }
    body.home a { color: var(--fg); }
  </style>
<% end %>

<div class="wrap">
  <% if @client_name %>
    <h1>Continue to <span class="accent"><%= @client_name %></span>?</h1>
    <p class="lead">
      You're about to authorise <%= @client_name %> to access your
      mcp-analytics account. Click below to continue to the consent
      screen.
    </p>
  <% else %>
    <h1>Sign in to <span class="accent">mcp-analytics</span>.</h1>
    <p class="lead">
      Click below to confirm and reveal your API token.
    </p>
  <% end %>

  <%= form_with url: verify_confirm_path(token: params[:token]), method: :post, local: true do |f| %>
    <button type="submit" class="btn">
      <% if @client_name %>
        Continue to <%= @client_name %> →
      <% else %>
        Sign me in →
      <% end %>
    </button>
  <% end %>

  <div class="footer-link">
    Didn't request this? Just close the tab — clicking nothing keeps the
    link unused.
  </div>
</div>
