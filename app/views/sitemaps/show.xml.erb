<%= raw '<?xml version="1.0" encoding="UTF-8"?>' %>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
<% @entries.each do |e| %>
  <url>
    <loc><%= e[:loc] %></loc>
    <% if e[:lastmod] %><lastmod><%= e[:lastmod] %></lastmod><% end %>
    <changefreq><%= e[:changefreq] %></changefreq>
    <priority><%= e[:priority] %></priority>
  </url>
<% end %>
</urlset>
