# Kept as reference. In normal use you do NOT need a .env file —
# KAMAL_REGISTRY_PASSWORD lives in ~/.zshrc (or your shell's rc) so
# every interactive shell already has it. The other secrets are
# resolved automatically by .kamal/secrets:
#   - RAILS_MASTER_KEY     → from config/master.key
#   - CLICKHOUSE_PASSWORD  → from encrypted credentials.yml.enc
#
# Only copy this to .env if you prefer per-project secret isolation
# instead of a global ~/.zshrc entry.

export KAMAL_REGISTRY_PASSWORD=
