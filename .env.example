# Local secrets for Kamal deploys.
# Copy to .env, fill in real values, then `source .env` before running
# `kamal` commands. .env is gitignored.

# GitHub Container Registry — Personal Access Token with scope: write:packages
# Generate at https://github.com/settings/tokens (classic, NOT fine-grained)
export KAMAL_REGISTRY_PASSWORD=

# Rails encrypted-credentials key. Read from config/master.key.
# Application secrets (Postmark API token, etc.) live INSIDE
# config/credentials.yml.enc — edit them via:
#   bin/rails credentials:edit
export RAILS_MASTER_KEY=$(cat config/master.key)

# ClickHouse password — generate ONCE on first deploy, then keep stable.
# Suggested: openssl rand -hex 32
export CLICKHOUSE_PASSWORD=
