# Secrets referenced by config/deploy.yml. This file is read by Kamal at deploy
# time; values come from the local shell environment. Do NOT commit real values.
#
# Usage:
#   source .env       # populates the variables below
#   kamal deploy
#
# Where the values live:
#   KAMAL_REGISTRY_PASSWORD   GHCR PAT (write:packages scope)
#   RAILS_MASTER_KEY          $(cat config/master.key) — decrypts credentials.yml.enc
#                             which contains the Postmark API token
#   CLICKHOUSE_PASSWORD       Generated once via openssl rand, then stable

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
RAILS_MASTER_KEY=$RAILS_MASTER_KEY
CLICKHOUSE_PASSWORD=$CLICKHOUSE_PASSWORD
