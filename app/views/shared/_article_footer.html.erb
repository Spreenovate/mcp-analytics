<%# Shared footer CTA + meta below the article body.
    `lang` param is "en" or "de". %>
<% lang = local_assigns[:lang] || "en" %>
<div class="article-cta">
  <% if lang == "de" %>
    <h3>Web Analytics ohne Dashboard — frag Claude direkt.</h3>
    <p>Trage deine Email ein, klicke den Bestätigungslink, kopiere den Tracking-Snippet, frag deine Stats in Claude oder ChatGPT. Free bis 100k Hits/Monat, keine Kreditkarte.</p>
    <a href="/" class="button">Account anlegen →</a>
  <% else %>
    <h3>Web analytics with no dashboard — ask Claude instead.</h3>
    <p>Enter your email, click the verify link, paste the tracking snippet, ask your stats in Claude or ChatGPT. Free up to 100k hits/month, no credit card.</p>
    <a href="/" class="button">Create account →</a>
  <% end %>
</div>

<footer class="lp">
  <span>© <%= Date.current.year %> Spreenovate GmbH · Berlin · EU-hosted</span>
  <span>
    <a href="/privacy">Privacy</a> · <a href="/terms">Terms</a> · <a href="/docs">Docs</a>
  </span>
</footer>
