<% content_for(:title, "Docs | mcp-analytics") %>
<% content_for(:meta_description, "How mcp-analytics works. For humans — your agent only needs the MCP URL.") %>
<% content_for(:body_class, "home") %>
<% content_for :head do %>
  <%= render "pages/brutalist_doc_styles" %>

  <style>
    /* ---- The 'these docs are for humans' callout. Loud on purpose. ---- */
    body.home .agent-notice {
      position: relative;
      background: var(--fg); color: var(--bg);
      padding: 32px 32px 28px;
      border: var(--border) solid var(--fg);
      margin: 0 0 56px;
      box-shadow: 8px 8px 0 var(--accent);
    }
    body.home .agent-notice .meta-label {
      display: inline-block;
      background: var(--accent); color: var(--fg);
      padding: 4px 10px;
      font-family: "JetBrains Mono", monospace;
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.18em;
      margin-bottom: 14px;
    }
    body.home .agent-notice h2 {
      font-family: "Space Grotesk", sans-serif;
      font-weight: 900; font-size: clamp(26px, 4vw, 38px); line-height: 1.05;
      letter-spacing: -0.02em; margin: 0 0 12px;
      text-transform: none; color: var(--bg);
      border-bottom: 0; padding-bottom: 0;
    }
    body.home .agent-notice h2 em {
      font-style: normal; background: var(--accent); color: var(--fg);
      padding: 0 0.15em;
    }
    body.home .agent-notice p {
      font-size: 15px; margin: 0 0 22px; opacity: 0.85; max-width: 60ch;
    }
    body.home .agent-notice .cta {
      display: inline-block;
      background: var(--accent); color: var(--fg);
      padding: 14px 24px;
      font-family: "Space Grotesk", sans-serif; font-weight: 900;
      font-size: 15px; text-transform: uppercase; letter-spacing: 0.1em;
      text-decoration: none; border: 2px solid var(--accent);
      transition: transform 0.08s ease;
    }
    body.home .agent-notice .cta:hover {
      transform: translate(-2px, -2px);
      box-shadow: 4px 4px 0 var(--bg);
    }
    body.home .agent-notice .agent-aside {
      display: block;
      margin-top: 18px; font-size: 12px; opacity: 0.55;
      font-family: "JetBrains Mono", monospace;
    }

    /* ---- Quickstart cards ---- */
    body.home .quickstart {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
      margin: 16px 0 32px;
    }
    body.home .quickstart .step {
      border: var(--border) solid var(--fg); padding: 20px;
