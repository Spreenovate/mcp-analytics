<!DOCTYPE html>
<html lang="<%= content_for?(:lang) ? content_for(:lang) : 'en' %>">
  <head>
    <%
      page_title       = content_for?(:title) ? content_for(:title) : "mcp-analytics | web analytics. no dashboard. just answers."
      page_description = content_for?(:description) ? content_for(:description) :
        "Web analytics you query through Claude or any MCP client. No tabs, no dashboards, no cookie banners. EU-hosted."
      page_lang        = content_for?(:lang) ? content_for(:lang) : "en"
      og_locale        = page_lang == "de" ? "de_DE" : "en_US"
      base_url         = ENV.fetch("PUBLIC_BASE_URL", "https://mcp-analytics.com")
      canonical_url    = content_for?(:canonical_url) ? content_for(:canonical_url) : (base_url + request.path)
      og_image_url     = content_for?(:og_image_url) ? content_for(:og_image_url) : (base_url + "/og-image.png")
    %>

    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= page_description %>">
    <meta name="theme-color" content="#00FF88">
    <link rel="canonical" href="<%= canonical_url %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Favicons — .ico first so Safari falls back cleanly if SVG handling is flaky %>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="mask-icon" href="/icon.svg" color="#0a0a0a">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Open Graph (Facebook, LinkedIn, Slack, Discord, iMessage) %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="mcp-analytics">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= og_image_url %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="mcp-analytics. No dashboard. No charts. Just answers.">
    <meta property="og:locale" content="<%= og_locale %>">
    <% if content_for?(:hreflang) %>
      <%= raw(content_for(:hreflang)) %>
    <% end %>

    <%# Twitter / X cards %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= og_image_url %>">
    <meta name="twitter:image:alt" content="mcp-analytics. No dashboard. No charts. Just answers.">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "mcp_ui", defer: true %>
    <% if content_for?(:track_event) %>
      <meta name="mcpa-track" content="<%= content_for(:track_event) %>"<%= content_for?(:track_props) ? raw(" " + content_for(:track_props)) : "" %>>
    <% end %>
    <%= yield :head %>

    <%# JSON-LD structured data, only on root. %>
    <% if request.path == "/" %>
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "mcp-analytics",
        "url": "<%= base_url %>",
        "image": "<%= og_image_url %>",
        "description": "<%= page_description %>",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Any (web-based, MCP-native)",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR",
          "description": "Free up to 100,000 hits/month, unlimited sites."
        },
        "publisher": {
          "@type": "Organization",
          "name": "Spreenovate GmbH",
          "url": "https://mcp-analytics.com",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Prenzlauer Allee 186",
            "postalCode": "10405",
            "addressLocality": "Berlin",
            "addressCountry": "DE"
          }
        }
      }
      </script>
    <% end %>

    <%# Dogfooding: mcp-analytics tracking its own site. The tracker host
        is in lockstep with the CSP initializer (script-src allowlist). %>
    <% if Rails.env.production? %>
      <script defer data-site="wjxayhdd" src="<%= ENV.fetch('TRACKER_BASE_URL', 'https://t.mcp-analytics.com') %>/script.js"></script>
    <% end %>
  </head>

  <body class="<%= content_for?(:body_class) ? content_for(:body_class) : '' %>">
    <main>
      <% if notice %><div class="notice"><%= notice %></div><% end %>
      <%= yield %>
    </main>
  </body>
</html>
