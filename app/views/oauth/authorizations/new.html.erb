<% content_for(:title, "Authorize #{@client.client_name} | mcp-analytics") %>
<%= render "shared_styles" %>

<div class="wrap">
  <h1>Authorize <span class="accent"><%= @client.client_name %></span>.</h1>
  <p class="lead">
    <strong><%= @client.client_name %></strong> wants to access your mcp-analytics account.
    Enter your email to continue.
  </p>

  <% if flash.now[:alert] %>
    <div class="alert"><%= flash.now[:alert] %></div>
  <% end %>

  <%= form_with url: oauth_authorize_start_path, method: :post, local: true, class: "oauth-form" do |f| %>
    <%= hidden_field_tag :request_token, @auth_request.request_token %>
    <%= email_field_tag :email, params[:email], placeholder: "you@example.com", required: true, autofocus: true, autocomplete: "email" %>
    <div class="actions">
      <button type="submit" class="btn">Send verification link</button>
    </div>
  <% end %>

  <div class="panel">
    <span class="label">What you're authorizing</span>
    <ul class="scopes">
      <li>Read your sites and analytics data</li>
      <li>Add new sites to your account</li>
      <li>Remove sites you've registered</li>
    </ul>
  </div>

  <div class="footer-link">
    No mcp-analytics account yet? You'll get one when you click the email link.
  </div>
</div>
