# Secrets referenced by config/deploy.yml. Read by Kamal at deploy time.
# Each line is bash-evaluated; values come from one of:
#   - shell environment      (GHCR token from ~/.zshrc or .env)
#   - a local file           (master.key, gitignored)
#   - bin/rails runner       (encrypted credentials, decrypted on the fly)
#
# Therefore on a fresh dev machine you only need TWO things:
#   1. config/master.key            (the only secret-at-rest, gitignored)
#   2. KAMAL_REGISTRY_PASSWORD      (in ~/.zshrc or .env, your GHCR PAT)
# Everything else lives encrypted in config/credentials.yml.enc and is
# pulled out via rails runner at deploy time.

# GHCR Personal Access Token (write:packages). Set in ~/.zshrc or .env.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Rails Master Key — directly from the file. No need to export it first.
RAILS_MASTER_KEY=$(cat config/master.key)

# ClickHouse password — pulled from encrypted credentials.
# Stored at credentials.clickhouse.password. Each line in this file is
# evaluated in its own subshell, so we re-export the master key inline.
CLICKHOUSE_PASSWORD=$(RAILS_MASTER_KEY=$(cat config/master.key) bin/rails runner 'puts Rails.application.credentials.dig(:clickhouse, :password)')
