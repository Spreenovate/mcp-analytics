# Local secret(s) for Kamal deploys. Copy to .env and fill in.
# .env is gitignored.
#
# Alternative: put KAMAL_REGISTRY_PASSWORD into ~/.zshrc and skip the
# .env file entirely. Either works — both end up as shell env at deploy
# time, which is what Kamal reads.

# GitHub Container Registry — Personal Access Token, scope: write:packages.
# Generate at https://github.com/settings/tokens (classic, NOT fine-grained).
export KAMAL_REGISTRY_PASSWORD=

# RAILS_MASTER_KEY and CLICKHOUSE_PASSWORD live elsewhere now:
#   - RAILS_MASTER_KEY     → config/master.key (file, gitignored)
#   - CLICKHOUSE_PASSWORD  → encrypted in config/credentials.yml.enc
# Both are pulled directly by .kamal/secrets at deploy time.
