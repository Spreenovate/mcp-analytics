<%# Article styles for /blog and /vs (and any markdown-rendered page).
    Builds on _brutalist_doc_styles with article-specific bits: meta
    line, kramdown table styling, blockquotes, callouts, byline.
    Include AFTER the base styles or in place of them. %>
<%= render "pages/brutalist_doc_styles" %>

<style>
  /* The brutalist styles use `body.home` selectors throughout. We re-use
     the class on blog/vs pages so all the shared rules apply. Article
     additions stay scoped to body.home.article so they don't bleed
     elsewhere. */
  body.home.article .wrap { max-width: 760px; }

  body.home.article .article-meta {
    font-family: "JetBrains Mono", monospace; font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: #555; margin: 0 0 32px;
    border-bottom: 2px solid var(--fg); padding-bottom: 8px;
  }
  body.home.article .article-meta .dot { margin: 0 8px; color: var(--accent); font-weight: 700; }
  body.home.article .article-meta a { color: #555; text-decoration: underline; }

  /* Kramdown auto-rendered headings inside the article body. h1 is
     reserved for the title in the layout, body starts at h2. */
  body.home.article .article-body h2 {
    font-family: "Space Grotesk", sans-serif; font-weight: 900;
    font-size: 28px; line-height: 1.1; letter-spacing: -0.01em;
    text-transform: none; margin: 56px 0 16px; padding-bottom: 0;
    border-bottom: 0;
  }
  body.home.article .article-body h2::before {
    content: "## "; color: var(--accent);
    font-family: "JetBrains Mono", monospace; font-size: 22px;
    font-weight: 700;
  }
  body.home.article .article-body h3 {
    font-family: "Space Grotesk", sans-serif; font-weight: 700;
    font-size: 20px; margin: 32px 0 12px; text-transform: none;
    letter-spacing: 0;
  }
  body.home.article .article-body h4 {
    font-family: "JetBrains Mono", monospace; font-weight: 700;
    font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em;
    margin: 24px 0 8px;
  }
  body.home.article .article-body p,
  body.home.article .article-body li { font-size: 16px; line-height: 1.65; }
  body.home.article .article-body ul,
  body.home.article .article-body ol { padding-left: 24px; margin: 12px 0 20px; }
  body.home.article .article-body li { margin: 0 0 6px; }
  body.home.article .article-body code {
    background: #f5f5f5; padding: 1px 6px; border: 1px solid #e2e2e2;
    font-family: "JetBrains Mono", monospace; font-size: 13px;
  }
  body.home.article .article-body pre {
    background: var(--fg); color: var(--accent);
    padding: 18px 22px; margin: 16px 0 24px;
    font-family: "JetBrains Mono", monospace; font-size: 13.5px;
    line-height: 1.55; overflow-x: auto;
    border: var(--border) solid var(--fg);
  }
  body.home.article .article-body pre code {
    background: none; border: 0; padding: 0; color: inherit; font-size: inherit;
  }
  body.home.article .article-body blockquote {
    border-left: var(--border) solid var(--accent);
    padding: 8px 0 8px 20px; margin: 16px 0 24px;
    color: #333; font-style: italic;
  }
  body.home.article .article-body blockquote p:last-child { margin: 0; }

  body.home.article .article-body table {
    width: 100%; border-collapse: collapse; margin: 16px 0 24px;
    font-family: "JetBrains Mono", monospace; font-size: 13.5px;
  }
  body.home.article .article-body table th,
  body.home.article .article-body table td {
    border: 2px solid var(--fg); padding: 10px 12px; text-align: left;
    vertical-align: top;
  }
  body.home.article .article-body table th {
    background: var(--fg); color: var(--bg);
    font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.12em;
  }

  body.home.article .article-body hr {
    border: 0; border-top: 2px solid var(--fg);
    margin: 40px 0;
  }

  body.home.article .article-body a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }
  body.home.article .article-body a:hover { background: var(--accent); text-decoration: none; }

  /* Callout. Wrap content in a <div class="callout"> in markdown via
     raw HTML (kramdown allows interleaved HTML). */
  body.home.article .article-body .callout {
    border: var(--border) solid var(--fg);
    background: #fafafa;
    padding: 18px 22px;
    margin: 24px 0;
  }
  body.home.article .article-body .callout p:first-child { margin-top: 0; }
  body.home.article .article-body .callout p:last-child { margin-bottom: 0; }

  /* Footer CTA shared between blog + vs + mcp-tools pages. */
  body.home.article .article-cta {
    margin: 72px 0 0;
    border: var(--border) solid var(--fg);
    padding: 32px;
    background: #fafafa;
  }
  body.home.article .article-cta h3 {
    font-family: "Space Grotesk", sans-serif; font-weight: 900;
    font-size: 24px; margin: 0 0 8px;
  }
  body.home.article .article-cta p { margin: 0 0 16px; font-size: 15px; }
  body.home.article .article-cta a.button {
    display: inline-block; background: var(--fg); color: var(--accent);
    padding: 12px 22px; font-family: "JetBrains Mono", monospace;
    font-size: 13px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; text-decoration: none;
    border: var(--border) solid var(--fg);
  }
  body.home.article .article-cta a.button:hover {
    background: var(--accent); color: var(--fg);
  }

  /* Index page card grid. */
  body.home .post-list { margin: 32px 0; }
  body.home .post-card {
    display: block; padding: 20px 0; border-bottom: 2px solid #e2e2e2;
    text-decoration: none; color: var(--fg);
  }
  body.home .post-card:hover { background: rgba(0, 255, 136, 0.08); }
  body.home .post-card .date {
    font-family: "JetBrains Mono", monospace; font-size: 12px;
    color: #555; text-transform: uppercase; letter-spacing: 0.1em;
  }
  body.home .post-card h3 {
    font-family: "Space Grotesk", sans-serif; font-weight: 900;
    font-size: 22px; line-height: 1.2; margin: 6px 0 6px;
    text-transform: none; letter-spacing: -0.01em;
  }
  body.home .post-card p { margin: 0; font-size: 14px; color: #444; }

  /* Lang-switcher (hreflang counterpart link). */
  body.home .lang-switch {
    font-family: "JetBrains Mono", monospace; font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.1em;
    display: inline-block;
    margin: 16px 0; padding: 6px 12px;
    background: #f5f5f5; border: 2px solid var(--fg);
  }
  body.home .lang-switch a { color: var(--fg); text-decoration: none; }
  body.home .lang-switch a:hover { background: var(--accent); }
</style>
